{
  "tasks": {
    "karabiner-generate": "deno run -P ./karabiner.ts"
  },
  "imports": {
    "karabiner-ts": "https://deno.land/x/karabinerts@1.38.0/deno.ts"
  },
  "fmt": {
    "lineWidth": 100
  },
  "permissions": {
    "default": {
      "read": [
        "./private_karabiner.json"
      ],
      "write": [
        "./private_karabiner.json"
      ]
    }
  }
}
