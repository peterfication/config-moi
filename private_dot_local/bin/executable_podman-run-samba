#!/usr/bin/env bash
set -euo pipefail

USER_NAME="sambauser"
USER_PASSWORD="test1234-"

CONTAINER_NAME="samba-server"
IMAGE="ghcr.io/servercontainers/samba:smbd-only-latest"

HOST_DATA_DIR="${HOME}/tmp/samba"
mkdir -p "${HOST_DATA_DIR}"

SAMBA_VOLUME_CONFIG_FILES=$'[files]\npath = /shares/files\nread only = yes\nbrowsable = yes\nguest ok = no\nvalid users = sambauser'

echo "Starting Samba server..."
echo
echo "Host: localhost"
echo "Port: 1445"
echo "User: ${USER_NAME}"
echo "Password: ${USER_PASSWORD}"
echo "Data dir: ${HOST_DATA_DIR}"
echo
echo "Example connect:"
echo "  smbclient -p 1445 //localhost/files -U ${USER_NAME} --password ${USER_PASSWORD}"
echo "  Finder's smb:// URL handler does not reliably support custom SMB ports."
echo

# Remove old container if it exists
if podman container exists "${CONTAINER_NAME}"; then
	podman rm -f "${CONTAINER_NAME}" >/dev/null
fi

# https://github.com/ServerContainers/samba
podman run --rm \
	--name "${CONTAINER_NAME}" \
	-e "ACCOUNT_${USER_NAME}=${USER_PASSWORD}" \
	-e "SAMBA_CONF_WORKGROUP=WORKGROUP" \
	-e "NETBIOS_DISABLE=true" \
	-e "AVAHI_DISABLE=true" \
	-e "WSDD2_DISABLE=true" \
	-e "SAMBA_VOLUME_CONFIG_files=${SAMBA_VOLUME_CONFIG_FILES}" \
	-p 1445:445 \
	-v "${HOST_DATA_DIR}:/shares/files" \
	"${IMAGE}"
