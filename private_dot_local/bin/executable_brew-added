#!/usr/bin/env bash
set -euo pipefail

KIND="${1:-core}"
shift || true

SINCE="${*:-1 month ago}"
CLONE_SINCE="6 months ago"
BASE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/homebrew-history"

case "$KIND" in
core | formula | formulae)
	KIND="core"
	REPO_NAME="homebrew-core"
	REPO_URL="https://github.com/Homebrew/homebrew-core.git"
	PATH_GLOB="Formula/**/*.rb"
	NAME_EXPR='s|^Formula/(.+/)?([^/]+)\.rb$|\2|p'
	;;
cask | casks)
	KIND="cask"
	REPO_NAME="homebrew-cask"
	REPO_URL="https://github.com/Homebrew/homebrew-cask.git"
	PATH_GLOB="Casks/**/*.rb"
	NAME_EXPR='s|^Casks/(.+/)?([^/]+)\.rb$|\2|p'
	;;
-h | --help | help)
	cat <<EOF
Usage:
  brew-added [core|cask] [since]

Defaults:
  kind   = core
  since  = "1 month ago"

Examples:
  brew-added
  brew-added cask
  brew-added core "2 weeks ago"
  brew-added cask "2026-06-01"

Output:
  name<TAB>description

Note:
  The local clone is shallow and keeps roughly the last 6 months of history.
EOF
	exit 0
	;;
*)
	echo "Error: first argument must be 'core' or 'cask'." >&2
	echo "Try: brew-added --help" >&2
	exit 1
	;;
esac

REPO_DIR="$BASE_DIR/$REPO_NAME"

mkdir -p "$BASE_DIR"

if [[ ! -d "$REPO_DIR/.git" ]]; then
	echo "Cloning $REPO_NAME with history since $CLONE_SINCE..." >&2
	git clone \
		--filter=blob:none \
		--shallow-since="$CLONE_SINCE" \
		"$REPO_URL" \
		"$REPO_DIR" >&2
else
	echo "Updating $REPO_NAME..." >&2
	git -C "$REPO_DIR" fetch \
		--prune \
		--shallow-since="$CLONE_SINCE" \
		origin >&2

	git -C "$REPO_DIR" pull --ff-only >&2
fi

extract_desc() {
	# shellcheck disable=SC2016
	ruby -e '
    content = STDIN.read

    # Matches: desc "Something" or desc '\''Something'\''
    if content =~ /^[[:space:]]*desc[[:space:]]+("(?:\\.|[^"])*"|'\''(?:\\.|[^'\''])*'\'')/
      puts eval($1)
    else
      puts ""
    end
  '
}

echo ""

git -C "$REPO_DIR" log \
	--since="$SINCE" \
	--diff-filter=A \
	--name-only \
	--pretty=format: \
	-- "$PATH_GLOB" |
	sort -u |
	while IFS= read -r path; do
		[[ -n "$path" ]] || continue

		name="$(printf '%s\n' "$path" | sed -nE "$NAME_EXPR")"
		[[ -n "$name" ]] || continue

		if content="$(git -C "$REPO_DIR" show "HEAD:$path" 2>/dev/null)"; then
			desc="$(printf '%s\n' "$content" | extract_desc)"
		else
			desc="[not present in current HEAD]"
		fi

		printf '%-32.32s  %s\n' "$name" "$desc"
	done
